# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# CDN Media Upload
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis Cache
REDIS_URL=redis://localhost:6379

# Authentication
JWT_ACCESS_SECRET=generate_random_secret_here
JWT_REFRESH_SECRET=generate_random_secret_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
SESSION_SECRET=generate_random_secret_here

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="ModernShop" <your_email@gmail.com>
FRONTEND_URL=https://yourdomain.com

# Payment Configuration
MERCHANT_UPI_ID=your_upi_id@bank

# Environment Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# Database Configuration
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_SOCKET_TIMEOUT_MS=45000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_ANALYTICS=false
ENABLE_ERROR_REPORTING=false
ENABLE_PERFORMANCE_MONITORING=false

# Carrier API Credentials
DELHIVERY_API_KEY=your_delhivery_api_key
DELHIVERY_API_URL=https://track.delhivery.com/api/cmu/json.json
BLUEDART_API_KEY=your_bluedart_api_key
BLUEDART_API_URL=https://api.bluedart.com/logistics/API
FEDEX_API_KEY=your_fedex_api_key
FEDEX_API_SECRET=your_fedex_api_secret
FEDEX_API_URL=https://apis.fedex.com
DTDC_API_KEY=your_dtdc_api_key
DTDC_API_URL=https://dtdc-api.dtdc.com
SHIPROCKET_API_KEY=your_shiprocket_api_key
SHIPROCKET_API_EMAIL=your_email@example.com
SHIPROCKET_API_URL=https://apiv2.shiprocket.in
